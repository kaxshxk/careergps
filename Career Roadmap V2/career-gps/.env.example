# =========================================================================
# CAREER GPS - ENVIRONMENT VARIABLES TEMPLATE
# =========================================================================
#
# INSTRUCTIONS ON WHERE TO PASTE YOUR API KEY:
#
# 1. Create a new file named ".env" in this exact directory:
#    <path-to-your-project>\.env
#
# 2. Open that new ".env" file in a text editor (e.g. Notepad, VS Code)
#
# 3. Paste the contents of this file into it, and replace the placeholder
#    value "YOUR_ACTUAL_GEMINI_API_KEY" with your real Google Gemini API Key.
#
#    Example:
#    GEMINI_API_KEY=AIzaSyA1B2C3D4...
#
# 4. Save and close the ".env" file.
# 
# =========================================================================

# Your Google Gemini API Key (get one for free/pay-as-you-go from Google AI Studio at: https://aistudio.google.com/)
GEMINI_API_KEY=YOUR_ACTUAL_GEMINI_API_KEY

# The model to use for generating your custom roadmap.
# Options:
# - gemini-2.5-flash (Recommended: extremely fast, high quality, native structured JSON support)
# - gemini-1.5-flash (Highly stable fallback)
# - gemini-1.5-pro (Extra smart, slightly slower)
GEMINI_MODEL=gemini-1.5-flash

# The port where your local secure backend proxy will run
PORT=5000

# The secret key for signing Flask sessions (Required for app.py)
SECRET_KEY=YOUR_SECURE_SECRET_KEY
